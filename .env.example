# Environment configuration template
# Copy this file and fill in real values for your environment.
# The real .env.* files are gitignored — never commit secrets.

# Database connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# Better Auth configuration
# URL where the app is hosted (used for auth callbacks and CORS)
BETTER_AUTH_URL=
# Must be a long random string (32+ chars) — use: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Public URL for the Better Auth client (accessible from browser)
NEXT_PUBLIC_BETTER_AUTH_URL=

# PostgreSQL connection details (used by docker-entrypoint.sh for health check)
DB_HOST=
DB_USER=

# Resend transactional email
# Get your API key from: Resend Dashboard -> API Keys -> Create API Key
# Dev: use the default onboarding@resend.dev "from" address (no domain verification needed)
# IMPORTANT: A verified domain is required for production sends.
#   Go to Resend Dashboard -> Domains -> Add Domain to verify your domain.
# SECURITY: Never use NEXT_PUBLIC_ prefix — this key must never reach the client bundle.
RESEND_API_KEY=
# From address for outgoing emails.
# Dev default: "Library <onboarding@resend.dev>" (falls back automatically if not set)
# Production: use a verified domain address, e.g. "Library <noreply@yourdomain.com>"
RESEND_FROM_EMAIL=Library <onboarding@resend.dev>
